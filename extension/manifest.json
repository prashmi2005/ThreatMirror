{
  "manifest_version": 3,
  "name": "ThreatMirror Guardian",
  "version": "1.0",
  "description": "Real-time AI email security assistant for Gmail.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}
